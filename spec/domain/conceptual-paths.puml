@startuml
title TPL Conceptual Paths (Scenario View)

hide methods
hide stereotypes
skinparam shadowing false
skinparam classAttributeIconSize 0
left to right direction

class User
class Role
class Permission

class Patient
class Episode
class MedicalValue

class Colloqium
class ColloqiumAgenda

class Coordination
class CoordinationEpisode
class CoordinationDonor

class TaskGroup
class Task

class Information
class InformationRead
class Favorite

' P1 - Access control path
User -[#1f4e79]-> Role : P1
Role -[#1f4e79]-> Permission : P1

' P2 - Patient care path
Patient -[#2e7d32]-> Episode : P2
Episode -[#2e7d32]-> MedicalValue : P2

' P3 - Colloquium workflow path
Patient -[#7b1fa2]-> Episode : P3
Episode -[#7b1fa2]-> ColloqiumAgenda : P3
Colloqium -[#7b1fa2]-> ColloqiumAgenda : P3
ColloqiumAgenda -[#7b1fa2]-> TaskGroup : P3
TaskGroup -[#7b1fa2]-> Task : P3

' P4 - Coordination workflow path
Coordination -[#ef6c00]-> CoordinationDonor : P4
Coordination -[#ef6c00]-> CoordinationEpisode : P4
CoordinationEpisode -[#ef6c00]-> Episode : P4
Coordination -[#ef6c00]-> TaskGroup : P4
TaskGroup -[#ef6c00]-> Task : P4

' P5 - Information visibility path
User -[#c62828]-> Information : P5 authored by
Information -[#c62828]-> InformationRead : P5
InformationRead -[#c62828]-> User : P5 read state

' P6 - Personal navigation path
User -[#546e7a]-> Favorite : P6
Favorite -[#546e7a]-> Patient : P6 (example target)

note bottom
Path legend:
P1 Access control (#1f4e79)
P2 Patient care (#2e7d32)
P3 Colloquium workflow (#7b1fa2)
P4 Coordination workflow (#ef6c00)
P5 Information visibility (#c62828)
P6 Personal navigation (favorites) (#546e7a)
end note

@enduml
