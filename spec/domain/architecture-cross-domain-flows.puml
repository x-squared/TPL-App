@startuml
title TPL Cross-Domain Process/Data Flow (high-level)

skinparam shadowing false
skinparam packageStyle rectangle

package "Patient Care" {
  class Patient
  class Episode
  class MedicalValue
}

package "Coordination" {
  class Coordination
  class CoordinationProcurementData
}

package "Tasking" {
  class TaskGroup
  class Task
}

package "Colloquiums" {
  class Colloqium
  class ColloqiumAgenda
}

Patient "1" --> "*" Episode : owns
Episode "1" --> "*" MedicalValue : context values
Episode "1" --> "*" Coordination : linked via coordination episode
Coordination "1" --> "*" CoordinationProcurementData : runtime data
Episode "1" --> "*" TaskGroup : scoped task groups
TaskGroup "1" --> "*" Task : work items
Episode "1" --> "*" ColloqiumAgenda : agenda context
Colloqium "1" --> "*" ColloqiumAgenda : contains

note right of MedicalValue
Canonical value + UCUM unit
for comparable reporting
end note

note bottom of Episode
Workflow actions move phase/status
through explicit backend services
end note

@enduml
